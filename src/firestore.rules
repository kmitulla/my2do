// ════════════════════════════════════════════════════════
//  FIRESTORE SECURITY RULES – 2Do App  (Version 0.3)
//  → Kopiere diese Rules in die Firebase Console:
//    Firebase Console → Firestore → Rules
//
//  NEU in 0.3: Admins (role == "admin" im eigenen users-Dokument)
//  dürfen alle users/{userId}-Dokumente lesen, ändern und löschen.
//  Ohne dieses Update funktioniert "Alle Users anzeigen",
//  Rollen ändern und User löschen im Admin-Panel NICHT.
// ════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ist der anfragende User ein Admin?
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── User-Profil-Dokument (users/{userId}) ────────────────────────────────
    // Owner: voller Zugriff · Admin: lesen (inkl. Liste), ändern, löschen
    match /users/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // ── User private data (todos, categories, settings, inbox, minimized) ───
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Public user profiles (for sharing feature) ──────────────────────────
    // Every authenticated user can read all profiles (to find users to share with)
    // Only the owner can write their own profile
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Shared todos (collaboration) ────────────────────────────────────────
    // Any authenticated user can create a shared todo
    // Sender, collaborators, or any target recipient can read/update
    match /sharedTodos/{todoId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        resource.data.sharedBy == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        request.auth.uid in resource.data.targetUids
      );
    }
  }
}
